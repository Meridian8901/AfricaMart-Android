{
  "expo": {
    "name": "AfricaMart",
    "slug": "africamart",
    "scheme": "co.africamart.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0D1B2A",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.africamart.app"
    },
    "android": {
      "package": "co.africamart.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "AfricaMart needs access to your photos to upload product images and store branding."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "75024675-5af8-456d-af6f-5fd75274b11a"
      }
    },
    "owner": "mohit8901"
  }
}
